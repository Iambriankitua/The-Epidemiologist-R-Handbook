library(tidyverse)
library(lubridate)

# Example dataset
linelist <- read_csv("linelist.csv")

# Create daily counts
daily_cases <- linelist %>%
  count(date_onset)

# Plot epidemic curve
ggplot(daily_cases, aes(x = date_onset, y = n)) +
  geom_col(fill = "steelblue") +
  labs(title = "Daily Cases")

# Moving average (7-day smoothing)
daily_cases <- daily_cases %>%
  mutate(ma7 = zoo::rollmean(n, 7, fill = NA))

ggplot(daily_cases, aes(date_onset)) +
  geom_line(aes(y = n), color = "grey") +
  geom_line(aes(y = ma7), color = "red")
library(deSolve)

sir_model <- function(time, state, parameters) {
  with(as.list(c(state, parameters)), {
    dS <- -beta * S * I
    dI <- beta * S * I - gamma * I
    dR <- gamma * I
    list(c(dS, dI, dR))
  })
}

init <- c(S = 0.99, I = 0.01, R = 0)
params <- c(beta = 0.3, gamma = 0.1)

times <- seq(0, 100, by = 1)

out <- ode(y = init, times = times, func = sir_model, parms = params)
out <- as.data.frame(out)

matplot(out$time, out[,2:4], type = "l", lty = 1,
        xlab = "Time", ylab = "Proportion")
