library(survey)

# Load data
survey_data <- read_csv("survey.csv")

# Define survey design (with weights)
design <- svydesign(
  ids = ~1,
  weights = ~weight,
  data = survey_data
)

# Estimate mean
svymean(~age, design)

# Proportion example
svymean(~I(sex == "Female"), design)
library(survival)
library(survminer)

# Example dataset
data <- read_csv("linelist.csv")

# Create survival object
surv_obj <- Surv(time = data$time_to_event,
                 event = data$outcome == "Death")

# Kaplan-Meier curve
fit <- survfit(surv_obj ~ 1)

ggsurvplot(fit, conf.int = TRUE)
library(sf)
library(ggplot2)

# Load shapefile
map <- st_read("shapefile.shp")

# Load case data
cases <- read_csv("cases.csv")

# Convert to spatial
cases_sf <- st_as_sf(cases, coords = c("lon", "lat"), crs = 4326)

# Plot map
ggplot() +
  geom_sf(data = map) +
  geom_sf(data = cases_sf, color = "red") +
  labs(title = "Geographic Distribution of Cases")
