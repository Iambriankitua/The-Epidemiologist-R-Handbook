# Example datasets
cases <- data.frame(id = 1:5, age = c(20, 30, 25, 40, 35))
lab <- data.frame(id = 1:5, result = c("pos", "neg", "pos", "neg", "pos"))

# Left join
merged_data <- left_join(cases, lab, by = "id")

# Inner join
merged_inner <- inner_join(cases, lab, by = "id")

merged_data
